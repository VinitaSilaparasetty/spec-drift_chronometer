# integrations/langchain_rag — environment variables
# Copy this file to .env and fill in your values. Never commit .env.

# Your OpenAI API key (required)
OPENAI_API_KEY=

# Warden Engine URL — use localhost if running dev.sh locally
WARDEN_API_URL=http://localhost:8000

# Governance dashboard URL
WARDEN_DASH_URL=http://localhost:3000
